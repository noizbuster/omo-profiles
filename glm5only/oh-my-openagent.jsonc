{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    // Main Agents
    "sisyphus": { // Claude Opus 4.6 Max
      "model": "zai-coding-plan/glm-5.1",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5",
        "zai-coding-plan/glm-5-turbo"
      ]
    },
    // "sisyphus-junior": { // AUTO
    //   "model": "zai-coding-plan/glm-5-turbo",
    //   "variant": "xhigh",
    //   "fallback_models": [
    //     "zai-coding-plan/glm-5.1",
    //     "zai-coding-plan/glm-5"
    //   ]
    // },
    "hephaestus": { // GPT 5.4 midium ~ high
      "model": "zai-coding-plan/glm-5.1",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5",
        "zai-coding-plan/glm-5-turbo"
      ]
    },
    "prometheus": { // Claude Opus 4.6 Max
      "model": "zai-coding-plan/glm-5.1",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5",
        "zai-coding-plan/glm-5-turbo"
      ]
    },
    "atlas": { // Claude Sonnet 4.6
      "model": "zai-coding-plan/glm-5-turbo",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "zai-coding-plan/glm-5"
      ]
    },
    "oracle": { // GPT 5.4 xHigh
      "model": "zai-coding-plan/glm-5.1",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5",
        "zai-coding-plan/glm-5-turbo"
      ]
    },
    "explore": { // MiniMax M2.5
      "model": "zai-coding-plan/glm-5-turbo",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "zai-coding-plan/glm-5"
      ]
    },
    "librarian": { // MiniMax M2.5
      "model": "zai-coding-plan/glm-5-turbo",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "zai-coding-plan/glm-5"
      ]
    },
    "metis": { // Claude Opus 4.6
      "model": "zai-coding-plan/glm-5.1",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5",
        "zai-coding-plan/glm-5-turbo"
      ]
    },
    "momus": { // GPT 5.4
      "model": "zai-coding-plan/glm-5.1",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5",
        "zai-coding-plan/glm-5-turbo"
      ]
    },
    "multimodal-looker": { // Multi Modal
      "model": "zai-coding-plan/glm-5v-turbo",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-4.5v",
        "openai/gpt-5.4-mini",
        "openai/gpt-5.4"
      ]
    }
  },
  "categories": {
    // Quick, Small, Cheap
    "quick": {
      "model": "zai-coding-plan/glm-5-turbo",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "zai-coding-plan/glm-5"
      ]
    },
    "git": {
      "model": "zai-coding-plan/glm-5-turbo",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "zai-coding-plan/glm-5"
      ]
    },
    "unspecified-low": {
      "model": "zai-coding-plan/glm-5-turbo",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "zai-coding-plan/glm-5"
      ]
    },
    // Smart, Heavy, Expensive
    "plan": {
      "model": "zai-coding-plan/glm-5.1",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5",
        "zai-coding-plan/glm-5-turbo"
      ]
    },
    "deep": {
      "model": "zai-coding-plan/glm-5.1",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5",
        "zai-coding-plan/glm-5-turbo"
      ]
    },
    "ultrabrain": {
      "model": "zai-coding-plan/glm-5.1",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5",
        "zai-coding-plan/glm-5-turbo"
      ]
    },
    "unspecified-high": {
      "model": "zai-coding-plan/glm-5.1",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5",
        "zai-coding-plan/glm-5-turbo"
      ]
    },
    "writing": {
      "model": "zai-coding-plan/glm-5.1",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5-turbo",
        "zai-coding-plan/glm-5"
      ]
    },
    // MultiModal
    "visual-engineering": {
      "model": "zai-coding-plan/glm-5.1",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5",
        "zai-coding-plan/glm-5-turbo"
      ]
    },
    "artistry": { // MultiModal
      "model": "zai-coding-plan/glm-5.1",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5",
        "zai-coding-plan/glm-5-turbo"
      ]
    }
  },
  "experimental": {
    "aggressive_truncation": true,
    "task_system": true
  },
  "tmux": {
    "enabled": false
  },
  "provider": {
    "zai-coding-plan": {
      "models": {
        "glm-5.1": { "limit": { "context": 100000 } },
        "glm-5": { "limit": { "context": 100000 } },
        "glm-5-turbo": { "limit": { "context": 100000 } },
        "glm-5v-turbo": { "limit": { "context": 100000 } }
      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  }
}
