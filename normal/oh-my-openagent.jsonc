{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "openai/gpt-5.4-fast",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "openai/gpt-5.4"
      ]
    },
    "hephaestus": {
      "model": "openai/gpt-5.4-fast",
      "variant": "high",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "openai/gpt-5.4-mini"
      ]
    },
    "prometheus": {
      "model": "openai/gpt-5.4-fast",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "openai/gpt-5.4-mini"
      ]
    },
    "atlas": {
      "model": "openai/gpt-5.4-fast",
      "variant": "high",
      "fallback_models": [
        "zai-coding-plan/glm-5-turbo",
        "zai-coding-plan/glm-5.1",
        "openai/gpt-5.3-codex",
        "openai/gpt-5.4-mini"
      ]
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "openai/gpt-5.3-codex",
        "openai/gpt-5.4-mini"
      ]
    },
    "explore": {
      "model": "openai/gpt-5.4-mini",
      "variant": "high",
      "fallback_models": [
        "zai-coding-plan/glm-5-turbo",
        "openai/gpt-5.4-mini",
        "openai/gpt-5.4"
      ]
    },
    "librarian": {
      "model": "openai/gpt-5.4-mini",
      "variant": "high",
      "fallback_models": [
        "zai-coding-plan/glm-5-turbo",
        "openai/gpt-5.4-mini",
        "openai/gpt-5.4"
      ]
    },
    "metis": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "openai/gpt-5.3-codex",
        "openai/gpt-5.4-mini"
      ]
    },
    "momus": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "openai/gpt-5.3-codex",
        "openai/gpt-5.4-mini"
      ]
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "openai/gpt-5.4-mini",
        "zai-coding-plan/glm-5v-turbo"
      ]
    }
  },
  "categories": {
    "quick": {
      "model": "openai/gpt-5.4-mini",
      "variant": "high",
      "fallback_models": [
        "zai-coding-plan/glm-5-turbo",
        "openai/gpt-5.4"
      ],
      "description": "Fast low-cost trivial edits, typo fixes, small single-file changes."
    },
    "git": {
      "model": "openai/gpt-5.4-mini",
      "variant": "high",
      "fallback_models": [
        "zai-coding-plan/glm-5-turbo",
        "openai/gpt-5.4"
      ]
    },
    "unspecified-low": {
      "model": "openai/gpt-5.4-mini",
      "variant": "high",
      "fallback_models": [
        "zai-coding-plan/glm-5-turbo",
        "openai/gpt-5.4"
      ]
    },
    "plan": {
      "model": "openai/gpt-5.4-fast",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "openai/gpt-5.3-codex",
        "openai/gpt-5.3-codex-spark",
        "openai/gpt-5.4-mini"
      ]
    },
    "deep": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "openai/gpt-5.3-codex",
        "openai/gpt-5.4-mini"
      ],
      "description": "Autonomous implementation, debugging, multi-step execution, and thorough coding work."
    },
    "ultrabrain": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "openai/gpt-5.3-codex",
        "openai/gpt-5.4-mini"
      ],
      "description": "Hard reasoning, architecture, root-cause analysis, difficult tradeoff decisions."
    },
    "unspecified-high": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "openai/gpt-5.3-codex",
        "openai/gpt-5.4-mini"
      ]
    },
    "writing": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "openai/gpt-5.4"
      ]
    },
    "visual-engineering": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "openai/gpt-5.3-codex",
        "openai/gpt-5.4-mini",
        "zai-coding-plan/glm-5v-turbo"
      ]
    },
    "artistry": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "openai/gpt-5.3-codex",
        "openai/gpt-5.4-mini",
        "zai-coding-plan/glm-5v-turbo"
      ]
    }
  },
  "experimental": {
    "aggressive_truncation": true,
    "task_system": true
  },
  "tmux": {
    "enabled": false
  }
}
