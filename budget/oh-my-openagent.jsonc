{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    // Main Agents
    "sisyphus": { // Claude Opus 4.6 Max
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "openai/gpt-5.4"
      ]
    },
    // "sisyphus-junior": { // AUTO
    //   "model": "openai/gpt-5.4",
    //   "variant": "high",
    //   "fallback_models": [
    //     "openai/gpt-5.4-mini",
    //     "zai-coding-plan/glm-5-turbo"
    //   ]
    // },
    "hephaestus": { // GPT 5.4 midium ~ high
      "model": "openai/gpt-5.4",
      "variant": "high",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "openai/gpt-5.4-mini"
      ]
    },
    "prometheus": { // Claude Opus 4.6 Max
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "openai/gpt-5.4-mini"
      ]
    },
    "atlas": { // Claude Sonnet 4.6
      "model": "openai/gpt-5.4",
      "variant": "high",
      "fallback_models": [
        "zai-coding-plan/glm-5-turbo",
        "zai-coding-plan/glm-5.1",
        "openai/gpt-5.3-codex",
        "openai/gpt-5.4-mini"
      ]
    },
    // Sub Agents
    "oracle": { // GPT 5.4 xHigh
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "openai/gpt-5.3-codex",
        "openai/gpt-5.4-mini"
      ]
    },
    "explore": { // MiniMax M2.5
      "model": "openai/gpt-5.4-mini",
      "variant": "high",
      "fallback_models": [
        "zai-coding-plan/glm-5-turbo",
        "openai/gpt-5.4-mini",
        "openai/gpt-5.4"
      ]
    },
    "librarian": { // MiniMax M2.5
      "model": "openai/gpt-5.4-mini",
      "variant": "high",
      "fallback_models": [
        "zai-coding-plan/glm-5-turbo",
        "openai/gpt-5.4-mini",
        "openai/gpt-5.4"
      ]
    },
    "metis": { // Claude Opus 4.6
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "openai/gpt-5.3-codex",
        "openai/gpt-5.4-mini"
      ]
    },
    "momus": { // GPT 5.4
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "openai/gpt-5.3-codex",
        "openai/gpt-5.4-mini"
      ]
    },
    "multimodal-looker": { // Multi Modal
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "openai/gpt-5.4-mini",
        "zai-coding-plan/glm-5v-turbo"
      ]
    }
  },
  "categories": {
    // Quick, Small, Cheap
    "quick": {
      "model": "openai/gpt-5.4-mini",
      "variant": "high",
      "fallback_models": [
        "zai-coding-plan/glm-5-turbo",
        "openai/gpt-5.4"
      ],
      "description": "Fast low-cost trivial edits, typo fixes, small single-file changes."
    },
    "git": {
      "model": "openai/gpt-5.4-mini",
      "variant": "high",
      "fallback_models": [
        "zai-coding-plan/glm-5-turbo",
        "openai/gpt-5.4"
      ]
    },
    "unspecified-low": {
      "model": "openai/gpt-5.4-mini",
      "variant": "high",
      "fallback_models": [
        "zai-coding-plan/glm-5-turbo",
        "openai/gpt-5.4"
      ]
    },
    // Smart, Heavy, Expensive
    "plan": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "openai/gpt-5.3-codex",
        "openai/gpt-5.4-mini"
      ]
    },
    "deep": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "openai/gpt-5.3-codex",
        "openai/gpt-5.4-mini"
      ],
      "description": "Autonomous implementation, debugging, multi-step execution, and thorough coding work."
    },
    "ultrabrain": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "openai/gpt-5.3-codex",
        "openai/gpt-5.4-mini"
      ],
      "description": "Hard reasoning, architecture, root-cause analysis, difficult tradeoff decisions."
    },
    "unspecified-high": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "openai/gpt-5.3-codex",
        "openai/gpt-5.4-mini"
      ]
    },
    "writing": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "openai/gpt-5.4"
      ]
    },
    // MultiModal
    "visual-engineering": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "openai/gpt-5.3-codex",
        "openai/gpt-5.4-mini",
        "zai-coding-plan/glm-5v-turbo"
      ]
    },
    "artistry": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "openai/gpt-5.3-codex",
        "openai/gpt-5.4-mini",
        "zai-coding-plan/glm-5v-turbo"
      ]
    }
  },
  "experimental": {
    "aggressive_truncation": true,
    "task_system": true
  },
  "tmux": {
    "enabled": false
  },
  "_migrations": [
    "model-version:openai/gpt-5.3-codex->openai/gpt-5.4",
    "model-version:openai/gpt-5.3-codex->openai/gpt-5.4",
    "model-version:openai/gpt-5.3-codex->openai/gpt-5.4"
  ]
}
